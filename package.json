{
  "name": "rox-ui",
  "version": "0.5.0",
  "description": "Rox UI — a State-First / Transition-First motion + component design system for React. Semantic ontology of work (state, transition, event, runtime, monad, trace, validator), glass surfaces, light/dark/high-contrast themes, 50 scenes, Motion-only.",
  "license": "MIT",
  "author": "scharlesky",
  "homepage": "https://github.com/scharlesky/rox-ui",
  "repository": {
    "type": "git",
    "url": "https://github.com/scharlesky/rox-ui.git"
  },
  "keywords": [
    "react",
    "design-system",
    "ui",
    "motion",
    "framer-motion",
    "state-first",
    "glassmorphism",
    "dark-ui",
    "components"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tokens.css": "./src/tokens/tokens.css"
  },
  "files": ["src", "README.md", "PRD.md", "BRAINSTORM.md", "LICENSE"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "ladle": "ladle serve",
    "build:preview": "ladle serve --port 6006",
    "test:visual": "playwright test"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "motion": ">=11"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.13.0",
    "@ladle/react": "^4.1.0",
    "@playwright/test": "^1.48.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "axe-core": "^4.12.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.10.0",
    "vitest": "^4.1.8"
  }
}
